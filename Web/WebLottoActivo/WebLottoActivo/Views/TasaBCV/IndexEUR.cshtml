@model List<TasaBCV>
@{
    ViewData["Title"] = "Index";
}

<h1>TASA EUR</h1>

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-currency-euro"></i>Historial de tasa EUR</h2>

    <table class="table table-bordered table-hover table-striped">
        <thead class="table-info">
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Moneda</th>
                <th>Valor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.id</td>
                    <td>@row.date</td>
                    <td>@row.symbol</td>
                    <td>@row.value</td>
                </tr>
            }
        </tbody>
    </table>
</div>
