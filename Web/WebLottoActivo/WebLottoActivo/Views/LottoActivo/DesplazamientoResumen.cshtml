@using WebLottoActivo.Models.ViewModels
@model List<DesplazamientoResumen>
@{
    ViewData["Title"] = "Index";

}

<div class="container mt-4 page-bottom-padding">
    <h2 class="mb-4"><i class="bi bi-arrow-repeat"></i> Desplazamiento Resumen</h2>
    <!-- selector (use the form below) -->
    <!-- month/year selector (single) -->
    <form method="get" asp-action="DesplazamientoResumen" class="mb-3">
        <div class="row align-items-center g-2">
            <div class="col-auto">
                <label for="monthSelect" class="form-label fw-bold">Mes:</label>
            </div>
            <div class="col-auto">
                <select name="month" id="monthSelect" class="form-select" onchange="this.form.submit()">
                    @{ 
                        int selectedMonth = ViewBag.SelectedMonth != null ? (int)ViewBag.SelectedMonth : DateTime.Today.Month; 
                        int minYear = ViewBag.MinYear != null ? (int)ViewBag.MinYear : DateTime.Today.Year - 2;
                        int maxYear = ViewBag.MaxYear != null ? (int)ViewBag.MaxYear : DateTime.Today.Year;
                    }
                    <option value="0">Todas</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        if (m == selectedMonth)
                        {
                            <option value="@m" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                        else
                        {
                            <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <label for="yearSelect" class="form-label fw-bold">Año:</label>
            </div>
            <div class="col-auto">
                <select name="year" id="yearSelect" class="form-select" onchange="this.form.submit()">
                    <option value="0">Todas</option>
                    @for (int y = minYear; y <= maxYear; y++)
                    {
                        if (y == ViewBag.SelectedYear)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </div>
        </div>
    </form>

    @* <table id="desplazamientoResumen"  class="table table-bordered table-hover table-striped"> *@
    <div class="table-responsive">
        <table id="desplazamientoResumen" class="table table-sm table-bordered table-hover table-striped">
        <thead class="table-info">
            <tr>
                <th>Desplazamiento</th>
                <th>Desplazamiento Posterior</th>
                <th>Cantidad</th>
                <th>Ultima Fecha</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.Desplazamiento</td>
                    <td>@row.DesplazamientosPosteriores</td>
                    <td>@row.Cantidad</td>
                    <td>@row.Fecha</td>
                </tr>
            }
        </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#desplazamientoResumen').DataTable({
                pageLength: 25,
                order: [[1, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>
}
