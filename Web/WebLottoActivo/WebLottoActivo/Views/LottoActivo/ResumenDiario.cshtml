@using WebLottoActivo.Models.ViewModels
@model ResumenDiario

@{
    ViewData["Title"] = "Index";
    var today = Model.Today;
    var yesterday = Model.Yesterday;
    int columnasPorFila = 3;
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-clipboard2-check"></i> Resumen Diario
    </h2>

    <form method="post" asp-action="ResumenDiario" class="mb-3">
        <div class="row g-2">
            <div class="col-12 col-md-4">
                <label for="fecha" class="form-label fw-bold">Seleccione la fecha:</label>
                <input type="date" name="date" id="fecha" class="form-control" value="@ViewBag.Today" />
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Buscar</button>
            </div>
        </div>
    </form>
    <hr style="border: 1px solid #ccc; margin: 20px 0;" />
    <div class="row">
        <!-- Tabla de Hoy -->
        <div class="col-12 col-lg-6">
            <h5 class="text-center">@ViewBag.Yesterday</h5>
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped">
                    <thead class="table-info">
                        <tr>
                            @for (int i = 0; i < columnasPorFila; i++)
                            {
                                <th class="text-center">Animal</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < yesterday.Count; i += columnasPorFila)
                        {
                            <tr>
                                @for (int j = i; j < i + columnasPorFila; j++)
                                {
                                    if (j < yesterday.Count)
                                    {
                                        var row = yesterday[j];
                                        <td class="text-center align-middle">
                                            <div class="d-flex flex-column align-items-center">
                                                <img src="data:image/png;base64,@row.ImageB64"
                                                     alt="Imagen"
                                                     class="img-fluid"
                                                     style="max-width:75px; max-height:75px;" />
                                                <span class="mt-2 fw-bold text-wrap text-center">@row.Nombre</span>
                                                <span class="fw-light text-muted">@row.Hora</span>
                                                @if (@row.IsFlag)
                                                {
                                                    <span class="fw-bold text-danger">(@row.Desplazamiento)</span>
                                                }
                                                else
                                                {
                                                    <span class="fw-light text-muted">(@row.Desplazamiento)</span>
                                                }
                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td></td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tabla de Ayer -->
        <div class="col-12 col-lg-6">
            <h5 class="text-center">@ViewBag.Today</h5>
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped">
                    <thead class="table-info">
                        <tr>
                            @for (int i = 0; i < columnasPorFila; i++)
                            {
                                <th class="text-center">Animal</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < today.Count; i += columnasPorFila)
                        {
                            <tr>
                                @for (int j = i; j < i + columnasPorFila; j++)
                                {
                                    if (j < today.Count)
                                    {
                                        var row = today[j];
                                        <td class="text-center align-middle">
                                            <div class="d-flex flex-column align-items-center">
                                                <img src="data:image/png;base64,@row.ImageB64"
                                                     alt="Imagen"
                                                     class="img-fluid"
                                                     style="max-width:75px; max-height:75px;" />
                                                <span class="mt-2 fw-bold text-wrap text-center">@row.Nombre</span>
                                                <span class="fw-light text-muted">@row.Hora</span>
                                                @if(@row.IsFlag)
                                                {
                                                    <span class="fw-bold text-danger">(@row.Desplazamiento)</span>
                                                }
                                                else
                                                {
                                                    <span class="fw-light text-muted">(@row.Desplazamiento)</span>
                                                }

                                            </div>
                                        </td>
                                    }
                                    else
                                    {
                                        <td></td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
