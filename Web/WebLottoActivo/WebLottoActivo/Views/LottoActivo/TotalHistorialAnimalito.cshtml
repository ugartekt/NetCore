@using WebLottoActivo.Models.ViewModels
@model List<CantidadTotalAnimalitos>
@{
    ViewData["Title"] = "Index";

}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-arrow-repeat"></i> Total Historial Animalito</h2>
    <form method="get" asp-action="DesplazamientoResumen" class="mb-3">
        <div class="row align-items-center">
            <div class="col-auto">
                <label for="rangoDias" class="form-label fw-bold">Filtrar por rango:</label>
            </div>
            <div class="col-auto">
                <select name="rangoDias" id="rangoDias" class="form-select" onchange="this.form.submit()">
                    <option value="7" selected>Últimos 7 días</option>
                    <option value="15">Últimos 15 días</option>
                    <option value="0">Todas</option>
                </select>
            </div>
        </div>
    </form>

    @* <table id="desplazamientoResumen"  class="table table-bordered table-hover table-striped"> *@
    <table id="totalHistorialAnimalito" class="table table-sm table-bordered table-hover table-striped">
        <thead class="table-info">
            <tr>
                <th>Animalito</th>
                <th>Cantidad</th>
                <th>Ultima Fecha</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td class="text-center align-middle">
                        <div class="d-flex flex-row align-items-center justify-content-center gap-2">
                            <img src="data:image/png;base64,@row.ImageB64"
                                 alt="Imagen"
                                 class="img-fluid"
                                 style="max-width:60px; max-height:60px;" />
                            <div class="d-flex flex-column text-start">
                                <span class="fw-bold text-wrap">@row.Nombre</span>
                                <span class="fw-bold text-muted">(@row.Id)</span>
                            </div>
                        </div>
                    </td>

                    <td>@row.Cantidad</td>
                    <td>@row.UltimaFecha</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#totalHistorialAnimalito').DataTable({
                pageLength: 10,
                order: [[1, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>
}
