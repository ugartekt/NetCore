@using WebLottoActivo.Models.ViewModels
@model List<AnimalitoResumen>
@{
    ViewData["Title"] = "Animalito Resumen";
}

<div class="container mt-4 page-bottom-padding">
    <h2 class="mb-4"><i class="bi bi-egg-fried"></i> Animalito Resumen</h2>
    <form method="get" asp-action="AnimalitoResumen" class="mb-3">
        <div class="row align-items-center g-2">
            <div class="col-auto">
                <label for="monthSelect" class="form-label fw-bold">Mes:</label>
            </div>
            <div class="col-auto">
                <select name="month" id="monthSelect" class="form-select" onchange="this.form.submit()">
                    @{ 
                        int selectedMonth = ViewBag.SelectedMonth != null ? (int)ViewBag.SelectedMonth : DateTime.Today.Month; 
                    }
                    @for (int m = 1; m <= 12; m++)
                    {
                        if (m == selectedMonth)
                        {
                            <option value="@m" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                        else
                        {
                            <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <label for="yearSelect" class="form-label fw-bold">Año:</label>
            </div>
            <div class="col-auto">
                <select name="year" id="yearSelect" class="form-select" onchange="this.form.submit()">
                    @{ 
                        int selectedYear = ViewBag.SelectedYear != null ? (int)ViewBag.SelectedYear : DateTime.Today.Year; 
                        var startYear = selectedYear - 2; var endYear = selectedYear; 
                    }
                    @for (int y = startYear; y <= endYear; y++)
                    {
                        if (y == selectedYear)
                        {
                            <option value="@y" selected>@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
            </div>
        </div>
    </form>

    <div class="table-responsive">
        <table id="animalitoResumen" class="table table-sm table-bordered table-hover table-striped">
        <thead class="table-info">
            <tr>
                <th>Animalito</th>
                <th>Animalitos Posteriores</th>
                <th>Cantidad</th>
                <th>Ultima Fecha</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td class="text-center align-middle">
                        <div class="d-flex flex-row align-items-center justify-content-center gap-2">
                            <img src="data:image/png;base64,@row.ImageB64" alt="Imagen" class="img-fluid rounded" style="max-width:48px; max-height:48px;" />
                            <div class="d-flex flex-column text-start">
                                <span class="fw-bold text-wrap">@row.Nombre</span>
                                <span class="fw-bold text-muted">(@row.AnimalId)</span>
                            </div>
                        </div>
                    </td>

                    <td>
                        <div class="d-flex flex-wrap">
                            @foreach(var ap in row.AnimalPosteriores)
                            {
                                <div class="me-2 text-center">
                                    <img src="data:image/png;base64,@ap.ImageB64" alt="@ap.Nombre" class="rounded" style="max-width:36px; max-height:36px;" title="@ap.Nombre" />
                                </div>
                            }
                        </div>
                    </td>
                    <td>@row.Cantidad</td>
                    <td>@row.UltimaFecha</td>
                </tr>
            }
        </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#animalitoResumen').DataTable({
                pageLength: 25,
                order: [[2, 'desc']],
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                }
            });
        });
    </script>
}
